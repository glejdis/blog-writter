# =============================================================================
# blog-writer environment configuration
# =============================================================================
# Copy this file to .env and fill in the values you need. Anything left empty
# falls back to stub mode for that capability (handy for tests / dev without
# real cloud credentials).

# -----------------------------------------------------------------------------
# Mode
# -----------------------------------------------------------------------------
# When true, the pipeline runs end-to-end with stub agents and stub tools.
# No model calls, no network calls. Used by tests and `blog-writer new --stub`.
BLOG_WRITER_STUB=false

# -----------------------------------------------------------------------------
# Model provider (which backend the agents use)
# -----------------------------------------------------------------------------
# One of: foundry | azure_openai | openai | stub
BLOG_WRITER_PROVIDER=foundry

# -----------------------------------------------------------------------------
# Azure AI Foundry (preferred — hosts GPT-5.x, Claude, reasoning models, etc.)
# -----------------------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<your-project>
# Deployment names for each role (override defaults in models/config.py)
BLOG_WRITER_MODEL_ORCHESTRATOR=gpt-5.4
BLOG_WRITER_MODEL_IDEATION=gpt-5-mini
BLOG_WRITER_MODEL_INTERNAL_KNOWLEDGE=gpt-5-mini
BLOG_WRITER_MODEL_RESEARCH=gpt-5.4
BLOG_WRITER_MODEL_PLANNER=o4-mini
BLOG_WRITER_MODEL_POC_BUILDER=gpt-5.3-codex
BLOG_WRITER_MODEL_STYLIST=gpt-5-mini
BLOG_WRITER_MODEL_WRITER=claude-opus-4-7
BLOG_WRITER_MODEL_FACT_CHECKER=gpt-5-mini
BLOG_WRITER_MODEL_CRITIC=gpt-5.4

# -----------------------------------------------------------------------------
# Azure OpenAI (fallback when Foundry is not available)
# -----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# -----------------------------------------------------------------------------
# Plain OpenAI (dev convenience)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Tools
# -----------------------------------------------------------------------------
# Microsoft Learn Docs MCP server (official, no auth required).
MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp

# -----------------------------------------------------------------------------
# External search (Research agent)
# -----------------------------------------------------------------------------
# The Research agent is backed by the *custom* Learn Browser MCP server
# bundled with this repo (mcp_servers/learn_browser/). It wraps the official
# Microsoft Learn Docs MCP — no API key needed.
#
# Optional: lift the GitHub repo-search rate limit from 10 → 30 req/min by
# providing a personal access token (no scopes required for public search).
# GITHUB_TOKEN=
#
# Optional: override the on-disk cache directory for fetched Learn pages.
# Default: ~/.cache/blog-writer/learn_browser/
# LEARN_BROWSER_CACHE_DIR=

# -----------------------------------------------------------------------------
# Deep research (o3-deep-research) — ON by default for the external research stage
# -----------------------------------------------------------------------------
# The external-research stage uses the Foundry o3-deep-research model (agentic,
# Bing-grounded) by default. When the connection vars below are absent it
# automatically falls back to the lightweight Learn/GitHub search, so this is
# safe to leave unset. Opt out entirely with BLOG_WRITER_DEEP_RESEARCH=false.
BLOG_WRITER_DEEP_RESEARCH=true
#
# Connection details for the o3-deep-research run (the model is only available
# in a few regions, e.g. westus / norwayeast). All three are required to
# actually enable deep research:
# AZURE_AI_DEEP_RESEARCH_ENDPOINT=https://<acct>.services.ai.azure.com/api/projects/<proj>
# AZURE_AI_DEEP_RESEARCH_MODEL=o3-deep-research
# AZURE_AI_BING_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<acct>/projects/<proj>/connections/<bing-conn>
# Optional orchestration chat deployment (defaults to gpt-4o):
# AZURE_AI_DEEP_RESEARCH_AGENT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Foundry Bing-grounding connection (placeholder, not yet wired)
# -----------------------------------------------------------------------------
# Reserved for the day agent-framework ships a typed HostedWebSearchTool.
# Setting this today does nothing functional — leave empty unless you're
# experimenting with the agent-framework prerelease.
BING_GROUNDING_CONNECTION_NAME=

# Code sandbox: local | aca | stub
BLOG_WRITER_SANDBOX=local

# -----------------------------------------------------------------------------
# Workflow
# -----------------------------------------------------------------------------
# Maximum Writer<->Critic revision loops before forcing acceptance.
BLOG_WRITER_MAX_REVISIONS=3
# Critic threshold (0-100). Drafts scoring below this trigger a revision.
BLOG_WRITER_CRITIC_THRESHOLD=80
# Max in-scope Learn citations to keep per post (post-filter).
BLOG_WRITER_MAX_LEARN_HITS=5
# Max attempts the PoC Builder gets to produce a passing sample before giving up.
BLOG_WRITER_MAX_POC_ATTEMPTS=3
# Stylist agent: learn a house writing style from the example posts in
# knowledge_base/style_corpus/ and have the Writer follow it. No-op when the
# corpus is empty. Set to false to disable the stage entirely.
BLOG_WRITER_STYLE=true

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry) — all optional
# -----------------------------------------------------------------------------
# Print spans / metrics to the console (handy during development).
# BLOG_WRITER_TRACING_CONSOLE=true
#
# Ship to any OTLP-compatible collector (Jaeger, Tempo, OTel Collector,
# Azure AI Foundry / AI Toolkit VS Code extension, etc).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
#
# Ship to Azure Application Insights / Azure Monitor.
# Requires: pip install blog-writer[telemetry]
# APPLICATIONINSIGHTS_CONNECTION_STRING=
